# Slack (Socket Mode)
# Create an app at https://api.slack.com/apps
# Bot token (xoxb-): OAuth & Permissions -> Bot User OAuth Token
# App-level token (xapp-): Basic Information -> App-Level Tokens, scope: connections:write
# Enable Socket Mode in the app settings.
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=

# Optional: Events API (if you switch from Socket Mode)
# SLACK_SIGNING_SECRET=

# Database (for semantic layer refresh and engine)
# Either set DATABASE_URL or the individual vars below.
# DATABASE_URL=postgresql://user:password@host:5432/dbname
# DB_HOST=
# DB_PORT=5432
# DB_NAME=
# DB_USER=
# DB_PASSWORD=

# Semantic layer: organization used in pai path (e.g. ttyd/table_name)
# SEMANTIC_LAYER_ORG=ttyd
